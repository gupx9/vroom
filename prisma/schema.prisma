generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id               String       @id @default(uuid())
  username         String       @unique
  email            String       @unique
  password         String
  isVerified       Boolean      @default(false)
  otp              String?
  reputation       Int          @default(0)
  role             String       @default("user")  // "user" | "admin"
  bannedUntil      DateTime?
  createdAt        DateTime     @default(now())
  cars             Car[]
  dioramas         Diorama[]
  reviewsReceived  UserReview[] @relation("ReviewTarget")
  reviewsGiven     UserReview[] @relation("ReviewAuthor")
  reportsReceived  UserReport[] @relation("ReportTarget")
  reportsGiven     UserReport[] @relation("ReportAuthor")
}

model UserReview {
  id        String   @id @default(uuid())
  targetId  String
  target    User     @relation("ReviewTarget", fields: [targetId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  stars     Int
  comment   String?
  status    String   @default("approved") // "approved" | "pending"
  createdAt DateTime @default(now())

  @@unique([authorId, targetId])
}

model UserReport {
  id        String   @id @default(uuid())
  targetId  String
  target    User     @relation("ReportTarget", fields: [targetId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("ReportAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  reason    String
  status    String   @default("pending") // "pending" | "approved" | "rejected"
  createdAt DateTime @default(now())

  @@unique([authorId, targetId])
}

model Car {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageData    String   @db.Text
  brand        String   @default("")
  carModel     String   @default("")
  size         String   @default("1:64")
  condition    String   @default("Intact")
  price        Float    @default(0)
  sellingPrice Float    @default(0)
  description  String?
  forSale      Boolean  @default(false)
  forTrade     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Diorama {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageData    String?  @db.Text
  description  String
  price        Float    @default(0)
  sellingPrice Float    @default(0)
  forSale      Boolean  @default(false)
  forTrade     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
